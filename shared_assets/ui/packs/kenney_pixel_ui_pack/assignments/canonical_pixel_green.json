    },
    {
      "type": "drawable",
      "logical_name": "ui_button_secondary",
      "source": "drawable/button_secondary_grey_pixel.png",
      "target": "app/src/main/res/drawable/ui_button_secondary.png"
    },
    {
      "type": "drawable",
      "logical_name": "ui_button_icon",
      "source": "drawable/button_icon_yellow_pixel.png",
      "target": "app/src/main/res/drawable/ui_button_icon.png"
    },
    {
      "type": "drawable",
      "logical_name": "ui_panel",
      "source": "drawable/panel_space_pixel.png",
      "target": "app/src/main/res/drawable/ui_panel.png"
    },
    {
      "type": "drawable",
      "logical_name": "ui_card",
      "source": "drawable/panel_space_inlay_pixel.png",
      "target": "app/src/main/res/drawable/ui_card.png"
