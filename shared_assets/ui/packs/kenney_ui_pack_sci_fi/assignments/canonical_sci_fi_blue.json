{
  "preset_id": "canonical_sci_fi_blue",
  "title": "Canonical Sci-Fi Blue",
  "ui_skin": "skin_neon_future",
  "notes": "Maps the curated sci-fi button, panel, and font assets onto the repository canonical logical UI names for futuristic and space-action projects.",
  "assignments": [
    {
      "type": "drawable",
      "logical_name": "ui_button_primary",
      "source": "drawable/button_primary_sci_fi.png",
      "target": "app/src/main/res/drawable/ui_button_primary.png"
    },
    {
      "type": "drawable",
      "logical_name": "ui_button_secondary",
      "source": "drawable/button_secondary_sci_fi.png",
      "target": "app/src/main/res/drawable/ui_button_secondary.png"
    },
    {
      "type": "drawable",
      "logical_name": "ui_button_icon",
      "source": "drawable/button_icon_sci_fi.png",
      "target": "app/src/main/res/drawable/ui_button_icon.png"
    },
    {
      "type": "drawable",
      "logical_name": "ui_panel",
      "source": "drawable/panel_glass_sci_fi.png",
      "target": "app/src/main/res/drawable/ui_panel.png"
    },
    {
      "type": "drawable",
      "logical_name": "ui_card",
      "source": "drawable/panel_rectangle_sci_fi.png",
      "target": "app/src/main/res/drawable/ui_card.png"
    },
    {
      "type": "font",
      "logical_name": "kenney_future_narrow",
      "source": "font/kenney_future_narrow.ttf",
      "target": "app/src/main/res/font/kenney_future_narrow.ttf"
    }
  ]
}
