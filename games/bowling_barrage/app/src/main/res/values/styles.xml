<resources>
    <style name="TextAppearance.Game.Title" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textColor">@color/cst_text_primary</item>
        <item name="android:textSize">@dimen/cst_text_xxl</item>
    </style>
    <style name="TextAppearance.Game.Subtitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/cst_text_secondary</item>
        <item name="android:textSize">@dimen/cst_text_xl</item>
    </style>
    <style name="TextAppearance.Game.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/cst_text_secondary</item>
        <item name="android:textSize">@dimen/cst_text_m</item>
    </style>
    <style name="TextAppearance.Game.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/cst_text_muted</item>
        <item name="android:textSize">@dimen/cst_text_s</item>
    </style>
    <style name="TextAppearance.Game.HudValue" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/cst_text_primary</item>
        <item name="android:textSize">@dimen/cst_text_l</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextAppearance.Game.HudLabel" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/cst_text_muted</item>
        <item name="android:textSize">@dimen/cst_text_xs</item>
        <item name="android:textAllCaps">true</item>
    </style>
    <style name="Widget.Game.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/cst_text_on_primary</item>
        <item name="android:background">@drawable/ui_button_primary</item>
        <item name="android:paddingStart">@dimen/cst_pad_16</item>
        <item name="android:paddingEnd">@dimen/cst_pad_16</item>
        <item name="android:textSize">@dimen/cst_text_m</item>
    </style>
    <style name="Widget.Game.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/cst_text_on_secondary</item>
        <item name="android:background">@drawable/ui_button_secondary</item>
        <item name="android:paddingStart">@dimen/cst_pad_16</item>
        <item name="android:paddingEnd">@dimen/cst_pad_16</item>
        <item name="android:textSize">@dimen/cst_text_m</item>
    </style>
    <style name="Widget.Game.Button.Icon" parent="Widget.AppCompat.ImageButton">
        <item name="android:background">@drawable/ui_button_icon</item>
        <item name="android:padding">@dimen/cst_pad_8</item>
        <item name="android:tint">@color/cst_text_primary</item>
        <item name="android:scaleType">centerInside</item>
    </style>
    <style name="Widget.Game.Panel">
        <item name="android:background">@drawable/ui_panel</item>
        <item name="android:padding">@dimen/cst_pad_16</item>
    </style>
    <style name="Widget.Game.Card">
        <item name="android:background">@drawable/ui_card</item>
        <item name="android:padding">@dimen/cst_pad_12</item>
    </style>
    <style name="Widget.Game.Chip">
        <item name="android:background">@drawable/ui_chip</item>
        <item name="android:textColor">@color/cst_text_secondary</item>
        <item name="android:textSize">@dimen/cst_text_s</item>
        <item name="android:minWidth">@dimen/cst_hud_badge_min_w</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingLeft">@dimen/cst_pad_8</item>
        <item name="android:paddingTop">@dimen/cst_pad_4</item>
        <item name="android:paddingRight">@dimen/cst_pad_8</item>
        <item name="android:paddingBottom">@dimen/cst_pad_4</item>
    </style>
    <style name="Widget.Game.Badge">
        <item name="android:background">@drawable/ui_badge</item>
        <item name="android:textColor">@color/cst_text_primary</item>
        <item name="android:textSize">@dimen/cst_text_s</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minWidth">@dimen/cst_hud_badge_min_w</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingLeft">@dimen/cst_pad_8</item>
        <item name="android:paddingTop">@dimen/cst_pad_4</item>
        <item name="android:paddingRight">@dimen/cst_pad_8</item>
        <item name="android:paddingBottom">@dimen/cst_pad_4</item>
    </style>
    <style name="Widget.Game.Meter" parent="Widget.AppCompat.ProgressBar.Horizontal">
        <item name="android:progressDrawable">@drawable/ui_meter_fill</item>
        <item name="android:background">@drawable/ui_meter_track</item>
    </style>
</resources>
