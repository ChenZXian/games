<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/cst_shadow" />
            <corners android:radius="@dimen/cst_radius_xl" />
        </shape>
    </item>
    <item
        android:bottom="@dimen/cst_pad_2"
        android:left="@dimen/cst_pad_2"
        android:right="@dimen/cst_pad_2"
        android:top="@dimen/cst_pad_2">
        <shape android:shape="rectangle">
            <gradient android:angle="270" android:endColor="@color/cst_bg_alt" android:startColor="@color/cst_panel_bg" />
            <stroke android:width="@dimen/cst_stroke_m" android:color="@color/cst_accent_2" />
            <corners android:radius="@dimen/cst_radius_xl" />
        </shape>
    </item>
</layer-list>
