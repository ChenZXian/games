<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cst_bg_main">

    <com.android.boot.ui.GameView
        android:id="@+id/game_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/hud_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@drawable/ui_panel_header"
        android:minHeight="@dimen/cst_hud_height"
        android:orientation="horizontal"
        android:padding="@dimen/cst_pad_8">

        <TextView
            android:id="@+id/txt_coins"
            style="@style/TextAppearance.Game.HudValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/ui_badge"
            android:gravity="center"
            android:minWidth="@dimen/cst_hud_badge_min_w"
            android:text="0" />

        <TextView
            android:id="@+id/txt_level"
            style="@style/TextAppearance.Game.HudValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/ui_badge"
            android:gravity="center"
            android:minWidth="@dimen/cst_hud_badge_min_w"
            android:text="Lv1" />

        <ImageButton
            android:id="@+id/btn_pause"
            style="@style/Widget.Game.Button.Icon"
            android:layout_width="@dimen/cst_hud_icon_size"
            android:layout_height="@dimen/cst_hud_icon_size"
            android:src="@drawable/ic_pause" />

        <ImageButton
            android:id="@+id/btn_mute"
            style="@style/Widget.Game.Button.Icon"
            android:layout_width="@dimen/cst_hud_icon_size"
            android:layout_height="@dimen/cst_hud_icon_size"
            android:src="@drawable/ic_sound_on" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/panel_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/ui_panel"
        android:orientation="vertical"
        android:padding="@dimen/cst_pad_8">

        <TextView
            android:id="@+id/txt_target"
            style="@style/TextAppearance.Game.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/ui_chip"
            android:padding="@dimen/cst_pad_8"
            android:text="Target: Complete board deliveries" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cst_pad_8"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_feed"
                style="@style/Widget.Game.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Feed" />

            <Button
                android:id="@+id/btn_clean"
                style="@style/Widget.Game.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/cst_pad_8"
                android:layout_weight="1"
                android:text="Clean" />

            <Button
                android:id="@+id/btn_collect"
                style="@style/Widget.Game.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/cst_pad_8"
                android:layout_weight="1"
                android:text="Collect" />

            <Button
                android:id="@+id/btn_upgrade"
                style="@style/Widget.Game.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/cst_pad_8"
                android:layout_weight="1"
                android:text="Upgrade" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
