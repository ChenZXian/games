<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/game_over_overlay"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:gravity="center"
  android:visibility="gone"
  android:background="@color/cst_shadow"
  android:orientation="vertical">
  <LinearLayout android:layout_width="320dp" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/ui_dialog" android:padding="@dimen/cst_pad_16">
    <TextView android:id="@+id/txt_game_over" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_game_over" android:textAppearance="@style/TextAppearance.Game.Title" />
    <Button android:id="@+id/btn_restart" style="@style/Widget.Game.Button.Primary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/btn_restart" />
    <Button android:id="@+id/btn_game_over_menu" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/btn_menu" />
  </LinearLayout>
</LinearLayout>
