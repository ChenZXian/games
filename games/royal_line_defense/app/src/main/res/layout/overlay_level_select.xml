<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/level_select_overlay"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:gravity="center"
  android:visibility="gone"
  android:background="@color/cst_bg_alt"
  android:orientation="vertical">
  <LinearLayout android:layout_width="420dp" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/ui_dialog" android:padding="@dimen/cst_pad_16">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/level_select_title" android:textAppearance="@style/TextAppearance.Game.Subtitle" />
    <Button android:id="@+id/btn_level_1" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Level 1 Meadow Gate" />
    <Button android:id="@+id/btn_level_2" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Level 2 Canyon Fork" />
    <Button android:id="@+id/btn_level_3" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Level 3 Swamp Spiral" />
    <Button android:id="@+id/btn_level_4" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Level 4 Frost Bridge" />
    <Button android:id="@+id/btn_level_5" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Level 5 Volcano Throne" />
  </LinearLayout>
</LinearLayout>
