<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/cst_bg_main">

  <com.android.boot.ui.GameView
    android:id="@+id/game_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent" />

  <include layout="@layout/overlay_hud" />
  <include layout="@layout/overlay_menu" />
  <include layout="@layout/overlay_paused" />
  <include layout="@layout/overlay_game_over" />
  <include layout="@layout/overlay_level_select" />
</FrameLayout>
