<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/menu_overlay"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:gravity="center"
  android:orientation="vertical"
  android:background="@color/cst_bg_alt">
  <LinearLayout android:layout_width="380dp" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/ui_dialog" android:padding="@dimen/cst_pad_20">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/app_name" android:textAppearance="@style/TextAppearance.Game.Title" />
    <Button android:id="@+id/btn_start" style="@style/Widget.Game.Button.Primary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/btn_start" />
    <Button android:id="@+id/btn_levels" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/btn_levels" />
    <Button android:id="@+id/btn_help" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/btn_how_to_play" />
  </LinearLayout>
</LinearLayout>
