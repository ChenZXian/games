<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/cst_shadow" />
            <corners android:radius="@dimen/cst_radius_xl" />
        </shape>
    </item>
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient android:angle="270" android:startColor="@color/cst_panel_bg" android:endColor="@color/cst_bg_alt" />
            <stroke android:width="@dimen/cst_stroke_m" android:color="@color/cst_accent_2" />
            <corners android:radius="@dimen/cst_radius_xl" />
        </shape>
    </item>
</layer-list>
