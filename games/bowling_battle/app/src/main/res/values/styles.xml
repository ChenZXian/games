<resources>
    <style name="TextAppearance.Game.Title">
        <item name="android:textColor">@color/cst_text_primary</item>
        <item name="android:textSize">@dimen/cst_text_title</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextAppearance.Game.Subtitle">
        <item name="android:textColor">@color/cst_text_primary</item>
        <item name="android:textSize">@dimen/cst_text_subtitle</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextAppearance.Game.Body">
        <item name="android:textColor">@color/cst_text_secondary</item>
        <item name="android:textSize">@dimen/cst_text_body</item>
    </style>
    <style name="TextAppearance.Game.Caption">
        <item name="android:textColor">@color/cst_text_secondary</item>
        <item name="android:textSize">@dimen/cst_text_caption</item>
    </style>
    <style name="TextAppearance.Game.HudValue">
        <item name="android:textColor">@color/cst_text_primary</item>
        <item name="android:textSize">@dimen/cst_text_hud_value</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextAppearance.Game.HudLabel">
        <item name="android:textColor">@color/cst_text_secondary</item>
        <item name="android:textSize">@dimen/cst_text_hud_label</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Widget.Game.Button.Primary">
        <item name="android:background">@drawable/ui_button_primary</item>
        <item name="android:textColor">@color/cst_text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">@dimen/cst_button_height</item>
        <item name="android:paddingLeft">@dimen/cst_pad_l</item>
        <item name="android:paddingRight">@dimen/cst_pad_l</item>
    </style>
    <style name="Widget.Game.Button.Secondary">
        <item name="android:background">@drawable/ui_button_secondary</item>
        <item name="android:textColor">@color/cst_text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">@dimen/cst_button_height</item>
        <item name="android:paddingLeft">@dimen/cst_pad_l</item>
        <item name="android:paddingRight">@dimen/cst_pad_l</item>
    </style>
    <style name="Widget.Game.Button.Icon">
        <item name="android:background">@drawable/ui_button_icon</item>
    </style>
    <style name="Widget.Game.Panel">
        <item name="android:background">@drawable/ui_panel</item>
        <item name="android:padding">@dimen/cst_pad_m</item>
    </style>
    <style name="Widget.Game.Card">
        <item name="android:background">@drawable/ui_card</item>
        <item name="android:padding">@dimen/cst_pad_m</item>
    </style>
    <style name="Widget.Game.Chip">
        <item name="android:background">@drawable/ui_chip</item>
        <item name="android:paddingLeft">@dimen/cst_pad_s</item>
        <item name="android:paddingRight">@dimen/cst_pad_s</item>
        <item name="android:paddingTop">@dimen/cst_pad_xs</item>
        <item name="android:paddingBottom">@dimen/cst_pad_xs</item>
    </style>
    <style name="Widget.Game.Badge">
        <item name="android:background">@drawable/ui_badge</item>
        <item name="android:paddingLeft">@dimen/cst_pad_s</item>
        <item name="android:paddingRight">@dimen/cst_pad_s</item>
        <item name="android:paddingTop">@dimen/cst_pad_xs</item>
        <item name="android:paddingBottom">@dimen/cst_pad_xs</item>
    </style>
    <style name="Widget.Game.Meter">
        <item name="android:progressDrawable">@drawable/ui_meter_fill</item>
        <item name="android:minHeight">@dimen/cst_meter_height</item>
    </style>
</resources>
