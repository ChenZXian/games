<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cst_bg_main">

  <com.android.boot.ui.GameView
      android:id="@+id/game_view"
      android:layout_width="match_parent"
      android:layout_height="match_parent" />

  <LinearLayout
      android:id="@+id/hud_container"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="top"
      android:gravity="center_vertical"
      android:orientation="vertical"
      android:padding="@dimen/cst_pad_12"
      android:visibility="gone">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

      <LinearLayout
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:background="@drawable/ui_panel"
          android:orientation="horizontal"
          android:padding="@dimen/cst_pad_12">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
          <TextView
              android:id="@+id/txt_score_label"
              style="@style/TextAppearance.Game.HudLabel"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/label_score" />
          <TextView
              android:id="@+id/txt_score"
              style="@style/TextAppearance.Game.HudValue"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="0" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
          <TextView
              style="@style/TextAppearance.Game.HudLabel"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/label_health" />
          <TextView
              android:id="@+id/txt_health"
              style="@style/TextAppearance.Game.HudValue"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="5" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
          <TextView
              style="@style/TextAppearance.Game.HudLabel"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/label_wave" />
          <TextView
              android:id="@+id/txt_wave"
              style="@style/TextAppearance.Game.HudValue"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="1" />
        </LinearLayout>
      </LinearLayout>

      <ImageButton
          android:id="@+id/btn_pause"
          style="@style/Widget.Game.Button.Icon"
          android:layout_width="@dimen/cst_game_button_size"
          android:layout_height="@dimen/cst_game_button_size"
          android:layout_marginStart="@dimen/cst_pad_8"
          android:contentDescription="@string/hud_pause"
          android:src="@drawable/ic_pause"
          android:tint="@color/cst_text_primary" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/cst_pad_8"
        android:orientation="horizontal">

      <LinearLayout
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:background="@drawable/ui_badge"
          android:orientation="vertical"
          android:padding="@dimen/cst_pad_8">
        <TextView
            style="@style/TextAppearance.Game.HudLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_charge" />
        <TextView
            android:id="@+id/txt_charge"
            style="@style/TextAppearance.Game.HudValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0" />
      </LinearLayout>

      <LinearLayout
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_marginStart="@dimen/cst_pad_8"
          android:layout_weight="2"
          android:background="@drawable/ui_badge"
          android:orientation="vertical"
          android:padding="@dimen/cst_pad_8">
        <TextView
            style="@style/TextAppearance.Game.HudLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_special_meter" />
        <FrameLayout
            android:id="@+id/special_meter_track"
            style="@style/Widget.Game.Meter"
            android:layout_width="match_parent"
            android:layout_height="@dimen/cst_meter_height"
            android:layout_marginTop="@dimen/cst_pad_6">
          <View
              android:id="@+id/special_meter_fill"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:background="@drawable/ui_meter_fill"
              android:scaleX="0"
              android:transformPivotX="0" />
        </FrameLayout>
      </LinearLayout>

      <TextView
          android:id="@+id/txt_mode"
          style="@style/Widget.Game.Chip"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginStart="@dimen/cst_pad_8"
          android:minWidth="@dimen/cst_mode_chip_width"
          android:text="@string/label_mode_pull"
          android:textAppearance="@style/TextAppearance.Game.HudValue"
          android:textColor="@color/cst_text_primary" />
    </LinearLayout>
  </LinearLayout>

  <LinearLayout
      android:id="@+id/control_container"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="bottom"
      android:gravity="center_vertical"
      android:orientation="horizontal"
      android:padding="@dimen/cst_pad_12"
      android:visibility="gone">

    <Button
        android:id="@+id/btn_mode"
        style="@style/Widget.Game.Button.Secondary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/label_mode_pull" />

    <Button
        android:id="@+id/btn_special"
        style="@style/Widget.Game.Button.Primary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/cst_pad_12"
        android:layout_weight="1"
        android:text="@string/label_special" />
  </LinearLayout>

  <FrameLayout
      android:id="@+id/menu_overlay"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:background="@color/cst_overlay_scrim"
      android:padding="@dimen/cst_pad_24">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/ui_dialog"
        android:orientation="vertical"
        android:padding="@dimen/cst_pad_20">

      <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/menu_title"
          android:textAppearance="@style/TextAppearance.Game.Title" />

      <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="@dimen/cst_pad_4"
          android:text="@string/menu_tagline"
          android:textAppearance="@style/TextAppearance.Game.Subtitle" />

      <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="@dimen/cst_pad_12"
          android:text="@string/menu_pitch"
          android:textAppearance="@style/TextAppearance.Game.Body" />

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="@dimen/cst_pad_16"
          android:gravity="center_vertical"
          android:orientation="horizontal">
        <Button
            android:id="@+id/btn_start"
            style="@style/Widget.Game.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_start" />
        <ImageButton
            android:id="@+id/btn_mute"
            style="@style/Widget.Game.Button.Icon"
            android:layout_width="@dimen/cst_game_button_size"
            android:layout_height="@dimen/cst_game_button_size"
            android:layout_marginStart="@dimen/cst_pad_8"
            android:contentDescription="@string/btn_mute"
            android:src="@drawable/ic_sound_on"
            android:tint="@color/cst_text_primary" />
        <ImageButton
            android:id="@+id/btn_help"
            style="@style/Widget.Game.Button.Icon"
            android:layout_width="@dimen/cst_game_button_size"
            android:layout_height="@dimen/cst_game_button_size"
            android:layout_marginStart="@dimen/cst_pad_8"
            android:contentDescription="@string/btn_how_to_play"
            android:src="@drawable/ic_help"
            android:tint="@color/cst_text_primary" />
      </LinearLayout>

      <LinearLayout
          android:id="@+id/how_to_panel"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="@dimen/cst_pad_16"
          android:background="@drawable/ui_card"
          android:orientation="vertical"
          android:padding="@dimen/cst_pad_16"
          android:visibility="gone">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/menu_how_title"
            android:textAppearance="@style/TextAppearance.Game.Subtitle" />
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/cst_divider_thickness"
            android:layout_marginTop="@dimen/cst_pad_8"
            android:background="@drawable/ui_divider" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cst_pad_8"
            android:text="@string/menu_how_body"
            android:textAppearance="@style/TextAppearance.Game.Body" />
      </LinearLayout>
    </LinearLayout>
  </FrameLayout>

  <FrameLayout
      android:id="@+id/pause_overlay"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:background="@color/cst_overlay_scrim"
      android:padding="@dimen/cst_pad_24"
      android:visibility="gone">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/ui_dialog"
        android:orientation="vertical"
        android:padding="@dimen/cst_pad_20">
      <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/paused_title"
          android:textAppearance="@style/TextAppearance.Game.Title" />
      <Button
          android:id="@+id/btn_resume"
          style="@style/Widget.Game.Button.Primary"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="@dimen/cst_pad_16"
          android:text="@string/btn_resume" />
      <Button
          android:id="@+id/btn_pause_menu"
          style="@style/Widget.Game.Button.Secondary"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="@dimen/cst_pad_12"
          android:text="@string/btn_menu" />
    </LinearLayout>
  </FrameLayout>

  <FrameLayout
      android:id="@+id/game_over_overlay"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:background="@color/cst_overlay_scrim"
      android:padding="@dimen/cst_pad_24"
      android:visibility="gone">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/ui_dialog"
        android:orientation="vertical"
        android:padding="@dimen/cst_pad_20">
      <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/game_over_title"
          android:textAppearance="@style/TextAppearance.Game.Title" />
      <TextView
          android:id="@+id/txt_game_over_stats"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="@dimen/cst_pad_16"
          android:textAppearance="@style/TextAppearance.Game.Body" />
      <Button
          android:id="@+id/btn_restart"
          style="@style/Widget.Game.Button.Danger"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="@dimen/cst_pad_16"
          android:text="@string/btn_restart" />
      <Button
          android:id="@+id/btn_game_over_menu"
          style="@style/Widget.Game.Button.Secondary"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="@dimen/cst_pad_12"
          android:text="@string/btn_menu" />
    </LinearLayout>
  </FrameLayout>
</FrameLayout>
