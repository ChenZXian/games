<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
  <item android:bottom="@dimen/cst_panel_shadow_inset" android:left="@dimen/cst_panel_shadow_inset" android:right="@dimen/cst_panel_shadow_inset" android:top="@dimen/cst_panel_shadow_top">
    <shape android:shape="rectangle">
      <solid android:color="@color/cst_shadow" />
      <corners android:radius="@dimen/cst_radius_l" />
    </shape>
  </item>
  <item>
    <shape android:shape="rectangle">
      <gradient android:angle="270" android:endColor="@color/cst_bg_alt" android:startColor="@color/cst_panel_bg" />
      <stroke android:width="@dimen/cst_stroke_s" android:color="@color/cst_panel_stroke" />
      <corners android:radius="@dimen/cst_radius_l" />
    </shape>
  </item>
</layer-list>
