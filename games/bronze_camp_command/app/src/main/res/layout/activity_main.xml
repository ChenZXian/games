<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cst_bg_main">

    <com.android.boot.ui.GameView
        android:id="@+id/game_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/cst_playfield_margin_top"
        android:layout_marginEnd="@dimen/cst_playfield_margin_end"
        android:layout_marginBottom="@dimen/cst_playfield_margin_bottom" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@drawable/ui_panel_header"
        android:gravity="center_vertical"
        android:minHeight="@dimen/cst_hud_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/cst_pad_8"
        android:paddingTop="@dimen/cst_pad_6"
        android:paddingEnd="@dimen/cst_pad_8"
        android:paddingBottom="@dimen/cst_pad_6">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_food"
                style="@style/TextAppearance.Game.HudValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/cst_pad_6"
                android:layout_weight="1"
                android:background="@drawable/ui_badge"
                android:gravity="center"
                android:minWidth="@dimen/cst_hud_badge_min_w"
                android:padding="@dimen/cst_pad_6"
                android:text="Food 0" />

            <TextView
                android:id="@+id/tv_wood"
                style="@style/TextAppearance.Game.HudValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/cst_pad_6"
                android:layout_weight="1"
                android:background="@drawable/ui_badge"
                android:gravity="center"
                android:minWidth="@dimen/cst_hud_badge_min_w"
                android:padding="@dimen/cst_pad_6"
                android:text="Wood 0" />

            <TextView
                android:id="@+id/tv_stone"
                style="@style/TextAppearance.Game.HudValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/cst_pad_6"
                android:layout_weight="1"
                android:background="@drawable/ui_badge"
                android:gravity="center"
                android:minWidth="@dimen/cst_hud_badge_min_w"
                android:padding="@dimen/cst_pad_6"
                android:text="Stone 0" />

            <TextView
                android:id="@+id/tv_pop"
                style="@style/TextAppearance.Game.HudValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/ui_badge"
                android:gravity="center"
                android:minWidth="@dimen/cst_hud_badge_min_w"
                android:padding="@dimen/cst_pad_6"
                android:text="Pop 0" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/cst_pad_8"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/ui_chip"
                android:orientation="vertical"
                android:paddingStart="@dimen/cst_pad_8"
                android:paddingTop="@dimen/cst_pad_4"
                android:paddingEnd="@dimen/cst_pad_8"
                android:paddingBottom="@dimen/cst_pad_4">

                <TextView
                    android:id="@+id/tv_timer"
                    style="@style/TextAppearance.Game.HudValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00" />

                <TextView
                    android:id="@+id/tv_alert"
                    style="@style/TextAppearance.Game.HudLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scout" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_pause"
                style="@style/Widget.Game.Button.Icon"
                android:layout_width="@dimen/cst_hud_icon_size"
                android:layout_height="@dimen/cst_hud_icon_size"
                android:layout_marginStart="@dimen/cst_pad_6"
                android:src="@drawable/ic_pause" />

            <ImageButton
                android:id="@+id/btn_mute"
                style="@style/Widget.Game.Button.Icon"
                android:layout_width="@dimen/cst_hud_icon_size"
                android:layout_height="@dimen/cst_hud_icon_size"
                android:layout_marginStart="@dimen/cst_pad_6"
                android:src="@drawable/ic_sound_on" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="@dimen/cst_side_panel_width"
        android:layout_height="wrap_content"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="@dimen/cst_pad_8"
        android:background="@drawable/ui_panel"
        android:orientation="vertical"
        android:padding="@dimen/cst_pad_8">

        <Button
            android:id="@+id/btn_scout"
            style="@style/Widget.Game.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scout" />

        <Button
            android:id="@+id/btn_army"
            style="@style/Widget.Game.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cst_pad_6"
            android:text="Army" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="@dimen/cst_command_panel_width"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="@dimen/cst_pad_8"
        android:layout_marginBottom="@dimen/cst_pad_8"
        android:background="@drawable/ui_panel"
        android:orientation="vertical"
        android:paddingStart="@dimen/cst_pad_10"
        android:paddingTop="@dimen/cst_pad_8"
        android:paddingEnd="@dimen/cst_pad_10"
        android:paddingBottom="@dimen/cst_pad_10">

        <TextView
            android:id="@+id/tv_objective"
            style="@style/TextAppearance.Game.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/ui_chip"
            android:padding="@dimen/cst_pad_8"
            android:text="Destroy the Chief Hall or hold both Obelisks" />

        <TextView
            android:id="@+id/tv_hint"
            style="@style/TextAppearance.Game.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cst_pad_6"
            android:text="Assign villagers and scout the enemy camp" />

        <Button
            android:id="@+id/btn_build"
            style="@style/Widget.Game.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cst_pad_8"
            android:text="Build" />

        <Button
            android:id="@+id/btn_train"
            style="@style/Widget.Game.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cst_pad_6"
            android:text="Train" />

        <Button
            android:id="@+id/btn_upgrade"
            style="@style/Widget.Game.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cst_pad_6"
            android:text="Tech" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/menu_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/cst_shadow">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="34dp"
            android:layout_marginEnd="34dp"
            android:background="@drawable/ui_dialog"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                style="@style/TextAppearance.Game.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bronze Camp Command" />

            <TextView
                style="@style/TextAppearance.Game.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Gather food wood and stone, build a war camp, scout the rival chief, and time the decisive assault." />

            <Button
                android:id="@+id/btn_start_overlay"
                style="@style/Widget.Game.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/btn_start" />

            <Button
                android:id="@+id/btn_help_overlay"
                style="@style/Widget.Game.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/btn_how_to_play" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/pause_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/cst_shadow"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="34dp"
            android:layout_marginEnd="34dp"
            android:background="@drawable/ui_dialog"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                style="@style/TextAppearance.Game.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Command Paused" />

            <TextView
                style="@style/TextAppearance.Game.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Tap units or buildings to select, drag over units to form squads, and tap the map to move or attack." />

            <Button
                android:id="@+id/btn_resume_overlay"
                style="@style/Widget.Game.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/btn_resume" />

            <Button
                android:id="@+id/btn_restart_overlay"
                style="@style/Widget.Game.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/btn_restart" />

            <Button
                android:id="@+id/btn_menu_overlay"
                style="@style/Widget.Game.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/btn_menu" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/result_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/cst_shadow"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="34dp"
            android:layout_marginEnd="34dp"
            android:background="@drawable/ui_dialog"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tv_result_title"
                style="@style/TextAppearance.Game.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Result" />

            <TextView
                android:id="@+id/tv_result_body"
                style="@style/TextAppearance.Game.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Summary" />

            <Button
                android:id="@+id/btn_result_restart"
                style="@style/Widget.Game.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/btn_restart" />

            <Button
                android:id="@+id/btn_result_menu"
                style="@style/Widget.Game.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/btn_menu" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
