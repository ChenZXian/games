<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/cst_bg_main">

  <com.android.boot.ui.GameView
    android:id="@+id/game_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent" />

  <LinearLayout
    android:id="@+id/hud_bar"
    android:layout_width="match_parent"
    android:layout_height="@dimen/cst_hud_height"
    android:layout_gravity="top"
    android:background="@drawable/ui_panel_header"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingLeft="@dimen/cst_pad_12"
    android:paddingRight="@dimen/cst_pad_12">

    <TextView android:id="@+id/hud_wave" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textAppearance="@style/TextAppearance.Game.HudValue" />
    <TextView android:id="@+id/hud_score" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:textAppearance="@style/TextAppearance.Game.HudValue" />
    <TextView android:id="@+id/hud_gold" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:textAppearance="@style/TextAppearance.Game.HudValue" />
    <TextView android:id="@+id/hud_hp" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end" android:textAppearance="@style/TextAppearance.Game.HudValue" />
  </LinearLayout>

  <HorizontalScrollView
    android:id="@+id/skill_row"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:layout_marginBottom="@dimen/cst_pad_16"
    android:fillViewport="true"
    android:visibility="gone">
    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:background="@drawable/ui_panel"
      android:orientation="horizontal"
      android:padding="@dimen/cst_pad_8">
      <Button android:id="@+id/btn_card_1" style="@style/Widget.Game.Button.Secondary" android:layout_width="wrap_content" android:layout_height="wrap_content" />
      <Button android:id="@+id/btn_card_2" style="@style/Widget.Game.Button.Secondary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="@dimen/cst_pad_8" />
      <Button android:id="@+id/btn_card_3" style="@style/Widget.Game.Button.Secondary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="@dimen/cst_pad_8" />
      <Button android:id="@+id/btn_card_4" style="@style/Widget.Game.Button.Secondary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="@dimen/cst_pad_8" />
      <Button android:id="@+id/btn_card_5" style="@style/Widget.Game.Button.Secondary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="@dimen/cst_pad_8" />
      <Button android:id="@+id/btn_card_6" style="@style/Widget.Game.Button.Secondary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="@dimen/cst_pad_8" />
    </LinearLayout>
  </HorizontalScrollView>

  <LinearLayout
    android:id="@+id/level_panel"
    style="@style/Widget.Game.Panel"
    android:layout_width="@dimen/cst_panel_width"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:orientation="vertical">
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:text="@string/title_level_select" android:textAppearance="@style/TextAppearance.Game.Title" />
    <Button android:id="@+id/btn_level_1" style="@style/Widget.Game.Button.Primary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_12" android:text="@string/level_1" />
    <Button android:id="@+id/btn_level_2" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" android:text="@string/level_2" />
    <Button android:id="@+id/btn_level_3" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" android:text="@string/level_3" />
    <Button android:id="@+id/btn_level_4" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" android:text="@string/level_4" />
    <Button android:id="@+id/btn_level_5" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" android:text="@string/level_5" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/deck_panel"
    style="@style/Widget.Game.Panel"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_margin="@dimen/cst_pad_16"
    android:orientation="horizontal"
    android:visibility="gone">

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
      <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/title_card_pool" android:textAppearance="@style/TextAppearance.Game.Subtitle" />
      <ScrollView android:layout_width="match_parent" android:layout_height="220dp" android:layout_marginTop="@dimen/cst_pad_8" android:background="@drawable/ui_card">
        <LinearLayout android:id="@+id/pool_list" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="@dimen/cst_pad_8" />
      </ScrollView>
    </LinearLayout>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginLeft="@dimen/cst_pad_12" android:orientation="vertical">
      <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/title_selected_deck" android:textAppearance="@style/TextAppearance.Game.Subtitle" />
      <LinearLayout android:id="@+id/selected_slots" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="@dimen/cst_pad_8" />
      <Button android:id="@+id/btn_start" style="@style/Widget.Game.Button.Primary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_12" android:text="@string/btn_start" />
      <Button android:id="@+id/btn_clear" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" android:text="@string/btn_clear" />
      <Button android:id="@+id/btn_auto_pick" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" android:text="@string/btn_auto_pick" />
      <Button android:id="@+id/btn_back" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" android:text="@string/btn_back" />
    </LinearLayout>
  </LinearLayout>

  <LinearLayout android:id="@+id/pause_panel" style="@style/Widget.Game.Panel" android:layout_width="@dimen/cst_panel_width" android:layout_height="wrap_content" android:layout_gravity="center" android:orientation="vertical" android:visibility="gone">
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:text="@string/title_paused" android:textAppearance="@style/TextAppearance.Game.Title" />
    <Button android:id="@+id/btn_resume" style="@style/Widget.Game.Button.Primary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_16" android:text="@string/btn_resume" />
    <Button android:id="@+id/btn_menu" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" android:text="@string/btn_menu" />
  </LinearLayout>

  <LinearLayout android:id="@+id/game_over_panel" style="@style/Widget.Game.Panel" android:layout_width="@dimen/cst_panel_width" android:layout_height="wrap_content" android:layout_gravity="center" android:orientation="vertical" android:visibility="gone">
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:text="@string/title_game_over" android:textAppearance="@style/TextAppearance.Game.Title" />
    <Button android:id="@+id/btn_restart" style="@style/Widget.Game.Button.Primary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_16" android:text="@string/btn_restart" />
  </LinearLayout>

  <LinearLayout android:id="@+id/upgrade_panel" style="@style/Widget.Game.Panel" android:layout_width="@dimen/cst_panel_width" android:layout_height="wrap_content" android:layout_gravity="center" android:orientation="vertical" android:visibility="gone">
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:text="@string/title_upgrade" android:textAppearance="@style/TextAppearance.Game.Subtitle" />
    <Button android:id="@+id/btn_upgrade_a" style="@style/Widget.Game.Button.Primary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_12" />
    <Button android:id="@+id/btn_upgrade_b" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" />
    <Button android:id="@+id/btn_upgrade_c" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" />
  </LinearLayout>

  <TextView
    android:id="@+id/card_detail"
    style="@style/TextAppearance.Game.Body"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center_horizontal|bottom"
    android:layout_marginBottom="120dp"
    android:background="@drawable/ui_dialog"
    android:padding="@dimen/cst_pad_12"
    android:visibility="gone" />

  <ImageButton android:id="@+id/btn_pause" style="@style/Widget.Game.Button.Icon" android:layout_width="@dimen/cst_button_height" android:layout_height="@dimen/cst_button_height" android:layout_gravity="top|right" android:layout_marginTop="@dimen/cst_hud_height" android:layout_marginRight="@dimen/cst_pad_12" android:src="@drawable/ic_pause" android:contentDescription="@string/btn_resume" android:visibility="gone" />
</FrameLayout>
