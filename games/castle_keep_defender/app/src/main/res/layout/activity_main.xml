<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/cst_bg_main">

  <com.android.boot.ui.GameView
    android:id="@+id/game_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent" />

  <LinearLayout
    android:id="@+id/hud_bar"
    android:layout_width="match_parent"
    android:layout_height="@dimen/cst_hud_height"
    android:layout_gravity="top"
    android:background="@drawable/ui_panel_header"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingLeft="@dimen/cst_pad_12"
    android:paddingRight="@dimen/cst_pad_12">

    <TextView
      android:id="@+id/hud_wave"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:textAppearance="@style/TextAppearance.Game.HudValue" />

    <TextView
      android:id="@+id/hud_score"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:textAppearance="@style/TextAppearance.Game.HudValue" />

    <TextView
      android:id="@+id/hud_gold"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:textAppearance="@style/TextAppearance.Game.HudValue" />

    <TextView
      android:id="@+id/hud_hp"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="end"
      android:textAppearance="@style/TextAppearance.Game.HudValue" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/skill_row"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom|center_horizontal"
    android:layout_marginBottom="@dimen/cst_pad_16"
    android:background="@drawable/ui_panel"
    android:orientation="horizontal"
    android:padding="@dimen/cst_pad_8"
    android:visibility="gone">

    <Button
      android:id="@+id/btn_skill_oil"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="@string/btn_oil" />

    <Button
      android:id="@+id/btn_skill_freeze"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginLeft="@dimen/cst_pad_8"
      android:text="@string/btn_freeze" />

    <Button
      android:id="@+id/btn_skill_push"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginLeft="@dimen/cst_pad_8"
      android:text="@string/btn_push" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/menu_panel"
    style="@style/Widget.Game.Panel"
    android:layout_width="@dimen/cst_panel_width"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:orientation="vertical">

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center"
      android:text="@string/title_game"
      android:textAppearance="@style/TextAppearance.Game.Title" />

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_12"
      android:gravity="center"
      android:text="@string/hint_how_to_play"
      android:textAppearance="@style/TextAppearance.Game.Body" />

    <Button
      android:id="@+id/btn_start"
      style="@style/Widget.Game.Button.Primary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_16"
      android:text="@string/btn_start" />

    <Button
      android:id="@+id/btn_how"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8"
      android:text="@string/btn_how_to_play" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/pause_panel"
    style="@style/Widget.Game.Panel"
    android:layout_width="@dimen/cst_panel_width"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:visibility="gone">

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center"
      android:text="@string/title_paused"
      android:textAppearance="@style/TextAppearance.Game.Title" />

    <Button
      android:id="@+id/btn_resume"
      style="@style/Widget.Game.Button.Primary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_16"
      android:text="@string/btn_resume" />

    <Button
      android:id="@+id/btn_menu"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8"
      android:text="@string/btn_menu" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/game_over_panel"
    style="@style/Widget.Game.Panel"
    android:layout_width="@dimen/cst_panel_width"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:visibility="gone">

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center"
      android:text="@string/title_game_over"
      android:textAppearance="@style/TextAppearance.Game.Title" />

    <Button
      android:id="@+id/btn_restart"
      style="@style/Widget.Game.Button.Primary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_16"
      android:text="@string/btn_restart" />

    <Button
      android:id="@+id/btn_game_over_menu"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8"
      android:text="@string/btn_menu" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/upgrade_panel"
    style="@style/Widget.Game.Panel"
    android:layout_width="@dimen/cst_panel_width"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:visibility="gone">

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center"
      android:text="@string/title_upgrade"
      android:textAppearance="@style/TextAppearance.Game.Subtitle" />

    <Button
      android:id="@+id/btn_upgrade_a"
      style="@style/Widget.Game.Button.Primary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_12" />

    <Button
      android:id="@+id/btn_upgrade_b"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8" />

    <Button
      android:id="@+id/btn_upgrade_c"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8" />
  </LinearLayout>

  <ImageButton
    android:id="@+id/btn_pause"
    style="@style/Widget.Game.Button.Icon"
    android:layout_width="@dimen/cst_button_height"
    android:layout_height="@dimen/cst_button_height"
    android:layout_gravity="top|right"
    android:layout_marginTop="@dimen/cst_hud_height"
    android:layout_marginRight="@dimen/cst_pad_12"
    android:src="@drawable/ic_pause"
    android:contentDescription="@string/btn_resume"
    android:visibility="gone" />
</FrameLayout>
