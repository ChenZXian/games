<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cst_bg_main">

    <com.android.boot.ui.GameView
        android:id="@+id/game_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/hud_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@drawable/ui_panel_header"
        android:gravity="center_vertical"
        android:minHeight="@dimen/cst_hud_height"
        android:orientation="vertical"
        android:padding="@dimen/cst_pad_8"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txt_player_hp"
                style="@style/Widget.Game.Badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Castle 100" />

            <TextView
                android:id="@+id/txt_enemy_hp"
                style="@style/Widget.Game.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/cst_pad_8"
                android:text="Stronghold 100" />

            <TextView
                android:id="@+id/txt_phase"
                style="@style/Widget.Game.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/cst_pad_8"
                android:text="Skirmish" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btn_pause"
                style="@style/Widget.Game.Button.Icon"
                android:layout_width="@dimen/cst_hud_icon_size"
                android:layout_height="@dimen/cst_hud_icon_size"
                android:contentDescription="@string/btn_resume"
                android:src="@drawable/ic_pause" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cst_pad_6"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txt_energy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Energy 0"
                    android:textAppearance="@style/TextAppearance.Game.HudValue" />

                <ProgressBar
                    android:id="@+id/meter_energy"
                    style="@style/Widget.Game.Meter"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="@dimen/cst_pad_4"
                    android:max="100"
                    android:progress="0" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/cst_pad_8"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txt_oath_power"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Oath 0"
                    android:textAppearance="@style/TextAppearance.Game.HudValue" />

                <ProgressBar
                    android:id="@+id/meter_oath"
                    style="@style/Widget.Game.Meter"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="@dimen/cst_pad_4"
                    android:max="100"
                    android:progress="0" />
            </LinearLayout>

            <TextView
                android:id="@+id/txt_active_oath"
                style="@style/Widget.Game.Badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/cst_pad_8"
                android:text="Ember Oath" />
        </LinearLayout>

        <TextView
            android:id="@+id/txt_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cst_pad_4"
            android:text="Frontline holds"
            android:textAppearance="@style/TextAppearance.Game.Caption" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/action_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/ui_panel"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/cst_pad_8">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <Button android:id="@+id/btn_footman" style="@style/Widget.Game.Button.Secondary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Footman 15" />
                <Button android:id="@+id/btn_archer" style="@style/Widget.Game.Button.Secondary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="@dimen/cst_pad_6" android:layout_weight="1" android:text="Archer 20" />
                <Button android:id="@+id/btn_knight" style="@style/Widget.Game.Button.Secondary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="@dimen/cst_pad_6" android:layout_weight="1" android:text="Knight 35" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cst_pad_6"
                android:gravity="center"
                android:orientation="horizontal">

                <Button android:id="@+id/btn_cleric" style="@style/Widget.Game.Button.Secondary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Cleric 25" />
                <Button android:id="@+id/btn_war_mage" style="@style/Widget.Game.Button.Secondary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="@dimen/cst_pad_6" android:layout_weight="1" android:text="War Mage 30" />
                <Button android:id="@+id/btn_titan" style="@style/Widget.Game.Button.Secondary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="@dimen/cst_pad_6" android:layout_weight="1" android:text="Titan 60" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cst_pad_6"
                android:gravity="center"
                android:orientation="horizontal">

                <Button android:id="@+id/btn_ember" style="@style/Widget.Game.Button.Primary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Ember Oath" />
                <Button android:id="@+id/btn_storm" style="@style/Widget.Game.Button.Primary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="@dimen/cst_pad_6" android:layout_weight="1" android:text="Storm Oath" />
                <Button android:id="@+id/btn_sanctum" style="@style/Widget.Game.Button.Primary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="@dimen/cst_pad_6" android:layout_weight="1" android:text="Sanctum Oath" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cst_pad_6"
                android:gravity="center"
                android:orientation="horizontal">

                <Button android:id="@+id/btn_meteor" style="@style/Widget.Game.Button.Primary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Meteor" />
                <Button android:id="@+id/btn_chain" style="@style/Widget.Game.Button.Primary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="@dimen/cst_pad_6" android:layout_weight="1" android:text="Chain" />
                <Button android:id="@+id/btn_holy" style="@style/Widget.Game.Button.Primary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="@dimen/cst_pad_6" android:layout_weight="1" android:text="Surge" />
                <Button android:id="@+id/btn_hero_skill" style="@style/Widget.Game.Button.Danger" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="@dimen/cst_pad_6" android:layout_weight="1" android:text="Champion" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/menu_overlay"
        style="@style/Widget.Game.Panel"
        android:layout_width="420dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/ui_dialog"
        android:orientation="vertical">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Epic Campaign War" android:textAppearance="@style/TextAppearance.Game.Title" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" android:text="Forge the line, swear a Royal Oath, and break fortress after fortress." android:textAppearance="@style/TextAppearance.Game.Body" />
        <Button android:id="@+id/btn_campaign" style="@style/Widget.Game.Button.Primary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_16" android:text="Campaign" />
        <Button android:id="@+id/btn_menu_help" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" android:text="@string/btn_how_to_play" />
        <Button android:id="@+id/btn_menu_mute" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" android:text="@string/btn_mute" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/campaign_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/cst_bg_alt"
        android:padding="@dimen/cst_pad_16"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                style="@style/Widget.Game.Panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Royal Campaign Map" android:textAppearance="@style/TextAppearance.Game.Title" />
                <TextView android:id="@+id/txt_campaign_progress" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_6" android:text="Chapter 1 unlocked" android:textAppearance="@style/TextAppearance.Game.Body" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="@dimen/cst_pad_12" android:background="@drawable/ui_divider" />
                <Button android:id="@+id/btn_campaign_back" style="@style/Widget.Game.Button.Secondary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_12" android:text="Back To Menu" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/chapter_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cst_pad_16"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/prep_overlay"
        style="@style/Widget.Game.Panel"
        android:layout_width="420dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/ui_dialog"
        android:orientation="vertical"
        android:visibility="gone">
        <TextView android:id="@+id/txt_prep_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Border Clash" android:textAppearance="@style/TextAppearance.Game.Title" />
        <TextView android:id="@+id/txt_prep_enemy" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" android:text="Enemy bias" android:textAppearance="@style/TextAppearance.Game.Body" />
        <TextView android:id="@+id/txt_prep_feel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" android:text="Recommended battle feel" android:textAppearance="@style/TextAppearance.Game.Body" />
        <Button android:id="@+id/btn_prep_start" style="@style/Widget.Game.Button.Primary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_12" android:text="@string/btn_start" />
        <Button android:id="@+id/btn_prep_back" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" android:text="Return To Map" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/help_overlay"
        style="@style/Widget.Game.Panel"
        android:layout_width="460dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/ui_dialog"
        android:orientation="vertical"
        android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="How To Play" android:textAppearance="@style/TextAppearance.Game.Subtitle" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" android:text="Summon units with energy, swap Royal Oaths to shape new allies, cast spells on timing, and lead the Oath Champion to crack each chapter stronghold. Ember boosts melee and meteor impact. Storm sharpens ranged speed and chain arcs. Sanctum strengthens healing and fortification." android:textAppearance="@style/TextAppearance.Game.Body" />
        <Button android:id="@+id/btn_help_close" style="@style/Widget.Game.Button.Primary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_12" android:text="@string/btn_menu" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/pause_overlay"
        style="@style/Widget.Game.Panel"
        android:layout_width="360dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/ui_dialog"
        android:orientation="vertical"
        android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Paused" android:textAppearance="@style/TextAppearance.Game.Subtitle" />
        <Button android:id="@+id/btn_resume" style="@style/Widget.Game.Button.Primary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_12" android:text="@string/btn_resume" />
        <Button android:id="@+id/btn_pause_restart" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" android:text="@string/btn_restart" />
        <Button android:id="@+id/btn_pause_map" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" android:text="Return To Campaign Map" />
        <Button android:id="@+id/btn_pause_menu" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" android:text="@string/btn_menu" />
        <Button android:id="@+id/btn_pause_mute" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" android:text="@string/btn_mute" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/result_overlay"
        style="@style/Widget.Game.Panel"
        android:layout_width="400dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/ui_dialog"
        android:orientation="vertical"
        android:visibility="gone">
        <TextView android:id="@+id/txt_result_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Victory" android:textAppearance="@style/TextAppearance.Game.Title" />
        <TextView android:id="@+id/txt_result_summary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" android:text="Summary" android:textAppearance="@style/TextAppearance.Game.Body" />
        <Button android:id="@+id/btn_result_restart" style="@style/Widget.Game.Button.Primary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_12" android:text="@string/btn_restart" />
        <Button android:id="@+id/btn_result_map" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" android:text="Return To Campaign Map" />
        <Button android:id="@+id/btn_result_menu" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_8" android:text="@string/btn_menu" />
    </LinearLayout>
</FrameLayout>
