<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <solid android:color="@color/cst_meter_track" />
            <corners android:radius="@dimen/cst_radius_xl" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <gradient android:startColor="@color/cst_accent" android:endColor="@color/cst_accent_2" android:angle="0" />
                <corners android:radius="@dimen/cst_radius_xl" />
            </shape>
        </clip>
    </item>
</layer-list>
