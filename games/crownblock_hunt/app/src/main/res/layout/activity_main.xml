<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/cst_bg_main">

  <com.android.boot.ui.GameView
    android:id="@+id/game_surface"
    android:layout_width="match_parent"
    android:layout_height="match_parent" />

  <LinearLayout
    android:id="@+id/block_header"
    android:layout_width="240dp"
    android:layout_height="wrap_content"
    android:layout_gravity="top|start"
    android:layout_margin="@dimen/cst_pad_16"
    android:background="@drawable/ui_panel_header"
    android:orientation="vertical"
    android:padding="@dimen/cst_pad_12">
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="@string/hud_block"
      android:textAppearance="@style/TextAppearance.Game.HudLabel" />
    <TextView
      android:id="@+id/txt_block_title"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textAppearance="@style/TextAppearance.Game.Title"
      android:textSize="@dimen/cst_text_l" />
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_4"
      android:text="@string/hud_objective"
      android:textAppearance="@style/TextAppearance.Game.HudLabel" />
    <TextView
      android:id="@+id/txt_objective"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textAppearance="@style/TextAppearance.Game.Body" />
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_4"
      android:text="@string/hud_control"
      android:textAppearance="@style/TextAppearance.Game.HudLabel" />
    <TextView
      android:id="@+id/txt_control"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textAppearance="@style/TextAppearance.Game.Body" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/dossier_rail"
    android:layout_width="170dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center_vertical|start"
    android:layout_marginStart="@dimen/cst_pad_16"
    android:background="@drawable/ui_panel"
    android:orientation="vertical"
    android:padding="@dimen/cst_pad_12">
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="@string/hud_health"
      android:textAppearance="@style/TextAppearance.Game.HudLabel" />
    <TextView
      android:id="@+id/txt_health"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textAppearance="@style/TextAppearance.Game.HudValue" />
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_6"
      android:text="@string/hud_stamina"
      android:textAppearance="@style/TextAppearance.Game.HudLabel" />
    <TextView
      android:id="@+id/txt_stamina"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textAppearance="@style/TextAppearance.Game.HudValue" />
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_6"
      android:text="@string/hud_armor"
      android:textAppearance="@style/TextAppearance.Game.HudLabel" />
    <TextView
      android:id="@+id/txt_armor"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textAppearance="@style/TextAppearance.Game.HudValue" />
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_6"
      android:text="@string/hud_heat"
      android:textAppearance="@style/TextAppearance.Game.HudLabel" />
    <TextView
      android:id="@+id/txt_heat"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textAppearance="@style/TextAppearance.Game.HudValue" />
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_6"
      android:text="@string/hud_cash"
      android:textAppearance="@style/TextAppearance.Game.HudLabel" />
    <TextView
      android:id="@+id/txt_cash"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textAppearance="@style/TextAppearance.Game.HudValue" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/partner_rail"
    android:layout_width="184dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center_vertical|end"
    android:layout_marginEnd="@dimen/cst_pad_16"
    android:background="@drawable/ui_panel"
    android:orientation="vertical"
    android:padding="@dimen/cst_pad_12">
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="@string/hud_partner_a"
      android:textAppearance="@style/TextAppearance.Game.HudLabel" />
    <TextView
      android:id="@+id/txt_partner_1"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textAppearance="@style/TextAppearance.Game.HudValue" />
    <Button
      android:id="@+id/btn_partner_1"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_6" />
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_10"
      android:text="@string/hud_partner_b"
      android:textAppearance="@style/TextAppearance.Game.HudLabel" />
    <TextView
      android:id="@+id/txt_partner_2"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textAppearance="@style/TextAppearance.Game.HudValue" />
    <Button
      android:id="@+id/btn_partner_2"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_6" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/combat_slab"
    android:layout_width="248dp"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom|end"
    android:layout_marginEnd="@dimen/cst_pad_16"
    android:layout_marginBottom="160dp"
    android:background="@drawable/ui_panel"
    android:orientation="vertical"
    android:padding="@dimen/cst_pad_12">
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="@string/hud_weapon"
      android:textAppearance="@style/TextAppearance.Game.HudLabel" />
    <TextView
      android:id="@+id/txt_weapon"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textAppearance="@style/TextAppearance.Game.HudValue" />
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_4"
      android:text="@string/hud_ammo"
      android:textAppearance="@style/TextAppearance.Game.HudLabel" />
    <TextView
      android:id="@+id/txt_ammo"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textAppearance="@style/TextAppearance.Game.HudValue" />
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_4"
      android:text="@string/hud_combo"
      android:textAppearance="@style/TextAppearance.Game.HudLabel" />
    <TextView
      android:id="@+id/txt_combo"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textAppearance="@style/TextAppearance.Game.HudValue" />
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_4"
      android:text="@string/hud_finisher"
      android:textAppearance="@style/TextAppearance.Game.HudLabel" />
    <TextView
      android:id="@+id/txt_finisher"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textAppearance="@style/TextAppearance.Game.HudValue" />
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8"
      android:orientation="horizontal">
      <Button
        android:id="@+id/btn_swap"
        style="@style/Widget.Game.Button.Primary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/btn_swap_label" />
      <Button
        android:id="@+id/btn_reload"
        style="@style/Widget.Game.Button.Secondary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/cst_pad_6"
        android:layout_weight="1"
        android:text="@string/btn_reload_label" />
      <Button
        android:id="@+id/btn_pause"
        style="@style/Widget.Game.Button.Secondary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/cst_pad_6"
        android:layout_weight="1"
        android:text="II" />
    </LinearLayout>
  </LinearLayout>

  <LinearLayout
    android:id="@+id/controls_left"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom|start"
    android:layout_marginStart="@dimen/cst_pad_16"
    android:layout_marginBottom="@dimen/cst_pad_16"
    android:orientation="vertical">
    <Button
      android:id="@+id/btn_jump"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="68dp"
      android:layout_height="68dp"
      android:layout_gravity="center_horizontal"
      android:text="@string/btn_jump_label" />
    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8"
      android:orientation="horizontal">
      <Button
        android:id="@+id/btn_left"
        style="@style/Widget.Game.Button.Secondary"
        android:layout_width="76dp"
        android:layout_height="68dp"
        android:text="@string/btn_left_label" />
      <Button
        android:id="@+id/btn_right"
        style="@style/Widget.Game.Button.Secondary"
        android:layout_width="76dp"
        android:layout_height="68dp"
        android:layout_marginStart="@dimen/cst_pad_8"
        android:text="@string/btn_right_label" />
    </LinearLayout>
  </LinearLayout>

  <LinearLayout
    android:id="@+id/controls_right"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom|end"
    android:layout_marginEnd="@dimen/cst_pad_16"
    android:layout_marginBottom="@dimen/cst_pad_16"
    android:orientation="vertical">
    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="horizontal">
      <Button
        android:id="@+id/btn_light"
        style="@style/Widget.Game.Button.Primary"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:text="@string/btn_light_label" />
      <Button
        android:id="@+id/btn_heavy"
        style="@style/Widget.Game.Button.Primary"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginStart="@dimen/cst_pad_6"
        android:text="@string/btn_heavy_label" />
      <Button
        android:id="@+id/btn_dash"
        style="@style/Widget.Game.Button.Secondary"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginStart="@dimen/cst_pad_6"
        android:text="@string/btn_dash_label" />
    </LinearLayout>
    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_6"
      android:orientation="horizontal">
      <Button
        android:id="@+id/btn_shoot"
        style="@style/Widget.Game.Button.Primary"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:text="@string/btn_shoot_label" />
      <Button
        android:id="@+id/btn_special"
        style="@style/Widget.Game.Button.Primary"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginStart="@dimen/cst_pad_6"
        android:text="@string/btn_special_label" />
      <Button
        android:id="@+id/btn_interact"
        style="@style/Widget.Game.Button.Secondary"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginStart="@dimen/cst_pad_6"
        android:text="@string/btn_interact_label" />
    </LinearLayout>
  </LinearLayout>

  <LinearLayout
    android:id="@+id/menu_panel"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/ui_dialog"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/cst_pad_24">
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="@string/title_menu"
      android:textAppearance="@style/TextAppearance.Game.Title" />
    <TextView
      android:id="@+id/txt_menu_summary"
      android:layout_width="320dp"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_12"
      android:gravity="center"
      android:textAppearance="@style/TextAppearance.Game.Body" />
    <Button
      android:id="@+id/btn_new_campaign"
      style="@style/Widget.Game.Button.Primary"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_16"
      android:text="@string/btn_new_campaign" />
    <Button
      android:id="@+id/btn_open_board"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8"
      android:text="@string/btn_board" />
    <Button
      android:id="@+id/btn_open_safehouse"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8"
      android:text="@string/btn_safehouse" />
    <Button
      android:id="@+id/btn_help"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8"
      android:text="@string/btn_help" />
    <Button
      android:id="@+id/btn_mute"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8"
      android:text="@string/btn_mute" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/board_panel"
    android:layout_width="340dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="@drawable/ui_dialog"
    android:orientation="vertical"
    android:padding="@dimen/cst_pad_20"
    android:visibility="gone">
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="@string/title_board"
      android:textAppearance="@style/TextAppearance.Game.Title" />
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_10"
      android:gravity="center_vertical"
      android:orientation="horizontal">
      <Button
        android:id="@+id/btn_prev_district"
        style="@style/Widget.Game.Button.Secondary"
        android:layout_width="54dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_prev" />
      <TextView
        android:id="@+id/txt_board_selection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/cst_pad_8"
        android:layout_marginEnd="@dimen/cst_pad_8"
        android:layout_weight="1"
        android:gravity="center"
        android:textAppearance="@style/TextAppearance.Game.Body" />
      <Button
        android:id="@+id/btn_next_district"
        style="@style/Widget.Game.Button.Secondary"
        android:layout_width="54dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_next" />
    </LinearLayout>
    <TextView
      android:id="@+id/txt_board_summary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_10"
      android:textAppearance="@style/TextAppearance.Game.Body" />
    <Button
      android:id="@+id/btn_deploy"
      style="@style/Widget.Game.Button.Primary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_14"
      android:text="@string/btn_deploy" />
    <Button
      android:id="@+id/btn_board_safehouse"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8"
      android:text="@string/btn_safehouse" />
    <Button
      android:id="@+id/btn_board_menu"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8"
      android:text="@string/btn_menu" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/safehouse_panel"
    android:layout_width="340dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="@drawable/ui_dialog"
    android:orientation="vertical"
    android:padding="@dimen/cst_pad_20"
    android:visibility="gone">
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="@string/title_safehouse"
      android:textAppearance="@style/TextAppearance.Game.Title" />
    <TextView
      android:id="@+id/txt_safehouse_summary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_10"
      android:textAppearance="@style/TextAppearance.Game.Body" />
    <Button
      android:id="@+id/btn_heal"
      style="@style/Widget.Game.Button.Primary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_14"
      android:text="@string/btn_heal" />
    <Button
      android:id="@+id/btn_ammo"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8"
      android:text="@string/btn_ammo" />
    <Button
      android:id="@+id/btn_bench"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8"
      android:text="@string/btn_bench" />
    <Button
      android:id="@+id/btn_recruit"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8"
      android:text="@string/btn_recruit" />
    <Button
      android:id="@+id/btn_safehouse_board"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8"
      android:text="@string/btn_board" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/pause_panel"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="@drawable/ui_dialog"
    android:orientation="vertical"
    android:padding="@dimen/cst_pad_20"
    android:visibility="gone">
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="@string/title_paused"
      android:textAppearance="@style/TextAppearance.Game.Title" />
    <TextView
      android:id="@+id/txt_pause_summary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_10"
      android:textAppearance="@style/TextAppearance.Game.Body" />
    <Button
      android:id="@+id/btn_resume"
      style="@style/Widget.Game.Button.Primary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_14"
      android:text="@string/btn_resume" />
    <Button
      android:id="@+id/btn_retreat"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8"
      android:text="@string/btn_retreat" />
    <Button
      android:id="@+id/btn_pause_menu"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8"
      android:text="@string/btn_menu" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/result_panel"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="@drawable/ui_dialog"
    android:orientation="vertical"
    android:padding="@dimen/cst_pad_20"
    android:visibility="gone">
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="@string/title_result"
      android:textAppearance="@style/TextAppearance.Game.Title" />
    <TextView
      android:id="@+id/txt_result_summary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_10"
      android:textAppearance="@style/TextAppearance.Game.Body" />
    <Button
      android:id="@+id/btn_next_block"
      style="@style/Widget.Game.Button.Primary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_14"
      android:text="@string/btn_next_block" />
    <Button
      android:id="@+id/btn_result_safehouse"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8"
      android:text="@string/btn_safehouse" />
    <Button
      android:id="@+id/btn_result_board"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8"
      android:text="@string/btn_board" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/game_over_panel"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="@drawable/ui_dialog"
    android:orientation="vertical"
    android:padding="@dimen/cst_pad_20"
    android:visibility="gone">
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="@string/title_game_over"
      android:textAppearance="@style/TextAppearance.Game.Title" />
    <TextView
      android:id="@+id/txt_game_over_summary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_10"
      android:textAppearance="@style/TextAppearance.Game.Body" />
    <Button
      android:id="@+id/btn_retry"
      style="@style/Widget.Game.Button.Primary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_14"
      android:text="@string/btn_retry" />
    <Button
      android:id="@+id/btn_game_over_board"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8"
      android:text="@string/btn_board" />
    <Button
      android:id="@+id/btn_game_over_menu"
      style="@style/Widget.Game.Button.Secondary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_8"
      android:text="@string/btn_menu" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/help_panel"
    android:layout_width="360dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="@drawable/ui_dialog"
    android:orientation="vertical"
    android:padding="@dimen/cst_pad_20"
    android:visibility="gone">
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="@string/btn_help"
      android:textAppearance="@style/TextAppearance.Game.Title" />
    <TextView
      android:id="@+id/txt_help_summary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_10"
      android:textAppearance="@style/TextAppearance.Game.Body" />
    <Button
      android:id="@+id/btn_close_help"
      style="@style/Widget.Game.Button.Primary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/cst_pad_14"
      android:text="@string/btn_close" />
  </LinearLayout>
</FrameLayout>
