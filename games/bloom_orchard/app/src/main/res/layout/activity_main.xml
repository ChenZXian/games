<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cst_bg_main">

    <com.android.boot.ui.GameView
        android:id="@+id/game_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/top_hud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@drawable/ui_panel_header"
        android:gravity="center_vertical"
        android:minHeight="@dimen/cst_hud_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/cst_pad_12"
        android:paddingTop="@dimen/cst_pad_10"
        android:paddingEnd="@dimen/cst_pad_12"
        android:paddingBottom="@dimen/cst_pad_10">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/ui_card"
            android:orientation="vertical"
            android:padding="@dimen/cst_pad_8">

            <TextView
                style="@style/TextAppearance.Game.HudLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_coins" />

            <TextView
                android:id="@+id/tv_coins"
                style="@style/TextAppearance.Game.HudValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cst_pad_2"
                android:text="0" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/cst_pad_8"
            android:layout_weight="1"
            android:background="@drawable/ui_card"
            android:orientation="vertical"
            android:padding="@dimen/cst_pad_8">

            <TextView
                style="@style/TextAppearance.Game.HudLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_progress" />

            <TextView
                android:id="@+id/tv_level"
                style="@style/TextAppearance.Game.HudValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cst_pad_2"
                android:text="Lv 1  Combo 0" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/cst_pad_8"
            android:layout_weight="1"
            android:background="@drawable/ui_card"
            android:orientation="vertical"
            android:padding="@dimen/cst_pad_8">

            <TextView
                style="@style/TextAppearance.Game.HudLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_timer" />

            <TextView
                android:id="@+id/tv_timer"
                style="@style/TextAppearance.Game.HudValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cst_pad_2"
                android:text="08:00" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_pause"
            style="@style/Widget.Game.Button.Icon"
            android:layout_width="@dimen/cst_hud_icon_size"
            android:layout_height="@dimen/cst_hud_icon_size"
            android:layout_marginStart="@dimen/cst_pad_10"
            android:contentDescription="@string/label_pause"
            android:src="@drawable/ic_pause" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/ui_panel"
        android:orientation="vertical"
        android:paddingStart="@dimen/cst_pad_12"
        android:paddingTop="@dimen/cst_pad_10"
        android:paddingEnd="@dimen/cst_pad_12"
        android:paddingBottom="@dimen/cst_pad_12">

        <TextView
            android:id="@+id/tv_tool_hint"
            style="@style/TextAppearance.Game.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hint_tool_seed" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cst_pad_8"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_seed"
                style="@style/Widget.Game.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_seed_tool" />

            <Button
                android:id="@+id/btn_water"
                style="@style/Widget.Game.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/cst_pad_6"
                android:layout_weight="1"
                android:text="@string/btn_water_tool" />

            <Button
                android:id="@+id/btn_fertilizer"
                style="@style/Widget.Game.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/cst_pad_6"
                android:layout_weight="1"
                android:text="@string/btn_fertilizer_tool" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/menu_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/cst_overlay_scrim"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            style="@style/Widget.Game.Panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="@dimen/cst_pad_24"
            android:layout_marginEnd="@dimen/cst_pad_24"
            android:orientation="vertical"
            android:padding="@dimen/cst_pad_16">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textAppearance="@style/TextAppearance.Game.Title" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cst_pad_8"
                android:text="@string/body_menu"
                android:textAppearance="@style/TextAppearance.Game.Body" />

            <Button
                android:id="@+id/btn_start_overlay"
                style="@style/Widget.Game.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cst_pad_16"
                android:text="@string/btn_start" />

            <Button
                android:id="@+id/btn_help_overlay"
                style="@style/Widget.Game.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cst_pad_8"
                android:text="@string/btn_how_to_play" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/pause_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/cst_overlay_scrim"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            style="@style/Widget.Game.Panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="@dimen/cst_pad_24"
            android:layout_marginEnd="@dimen/cst_pad_24"
            android:orientation="vertical"
            android:padding="@dimen/cst_pad_16">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_paused"
                android:textAppearance="@style/TextAppearance.Game.Title" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cst_pad_8"
                android:text="@string/body_paused"
                android:textAppearance="@style/TextAppearance.Game.Body" />

            <Button
                android:id="@+id/btn_resume_overlay"
                style="@style/Widget.Game.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cst_pad_16"
                android:text="@string/btn_resume" />

            <Button
                android:id="@+id/btn_restart_overlay"
                style="@style/Widget.Game.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cst_pad_8"
                android:text="@string/btn_restart" />

            <Button
                android:id="@+id/btn_menu_overlay"
                style="@style/Widget.Game.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cst_pad_8"
                android:text="@string/btn_menu" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/result_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/cst_overlay_scrim"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            style="@style/Widget.Game.Panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="@dimen/cst_pad_24"
            android:layout_marginEnd="@dimen/cst_pad_24"
            android:orientation="vertical"
            android:padding="@dimen/cst_pad_16">

            <TextView
                android:id="@+id/tv_result_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_day_over"
                android:textAppearance="@style/TextAppearance.Game.Title" />

            <TextView
                android:id="@+id/tv_result_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cst_pad_8"
                android:text="@string/body_day_over"
                android:textAppearance="@style/TextAppearance.Game.Body" />

            <Button
                android:id="@+id/btn_result_restart"
                style="@style/Widget.Game.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cst_pad_16"
                android:text="@string/btn_restart" />

            <Button
                android:id="@+id/btn_result_menu"
                style="@style/Widget.Game.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cst_pad_8"
                android:text="@string/btn_menu" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
