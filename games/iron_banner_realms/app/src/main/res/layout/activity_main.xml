<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cst_bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/cst_top_ribbon_h"
            android:background="@drawable/ui_panel_header"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="@dimen/cst_pad_12"
            android:paddingRight="@dimen/cst_pad_12">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_province"
                    android:textAppearance="@style/TextAppearance.Game.HudLabel" />
                <TextView
                    android:id="@+id/province_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_menu_ready"
                    android:textAppearance="@style/TextAppearance.Game.HudValue" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_owned"
                    android:textAppearance="@style/TextAppearance.Game.HudLabel" />
                <TextView
                    android:id="@+id/owned_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textAppearance="@style/TextAppearance.Game.HudValue" />
            </LinearLayout>

            <View
                android:layout_width="@dimen/cst_pad_12"
                android:layout_height="0dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_enemy"
                    android:textAppearance="@style/TextAppearance.Game.HudLabel" />
                <TextView
                    android:id="@+id/enemy_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textAppearance="@style/TextAppearance.Game.HudValue" />
            </LinearLayout>

            <View
                android:layout_width="@dimen/cst_pad_12"
                android:layout_height="0dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_income"
                    android:textAppearance="@style/TextAppearance.Game.HudLabel" />
                <TextView
                    android:id="@+id/income_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+0.0"
                    android:textAppearance="@style/TextAppearance.Game.HudValue" />
            </LinearLayout>

            <View
                android:layout_width="@dimen/cst_pad_12"
                android:layout_height="0dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_command"
                    android:textAppearance="@style/TextAppearance.Game.HudLabel" />
                <TextView
                    android:id="@+id/command_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0"
                    android:textAppearance="@style/TextAppearance.Game.HudValue" />
            </LinearLayout>

            <View
                android:layout_width="@dimen/cst_pad_12"
                android:layout_height="0dp" />

            <Button
                android:id="@+id/btn_pause"
                style="@style/Widget.Game.Button.Primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_pause"
                android:textAllCaps="false" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="@dimen/cst_left_rail_w"
                android:layout_height="match_parent"
                android:background="@drawable/ui_panel"
                android:orientation="vertical"
                android:padding="@dimen/cst_pad_12">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_objective"
                    android:textAppearance="@style/TextAppearance.Game.Subtitle" />
                <TextView
                    android:id="@+id/objective_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/cst_pad_6"
                    android:text="@string/label_objective_idle"
                    android:textAppearance="@style/TextAppearance.Game.Body" />
                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/cst_pad_16" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_doctrine"
                    android:textAppearance="@style/TextAppearance.Game.Subtitle" />
                <TextView
                    android:id="@+id/doctrine_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/cst_pad_6"
                    android:text="Log 0 Council 0 Iron 0"
                    android:textAppearance="@style/TextAppearance.Game.Body" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@color/cst_bg_alt"
                android:padding="@dimen/cst_pad_8">

                <com.android.boot.ui.GameView
                    android:id="@+id/game_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="@dimen/cst_right_rail_w"
                android:layout_height="match_parent"
                android:background="@drawable/ui_panel"
                android:orientation="vertical"
                android:padding="@dimen/cst_pad_12">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_alerts"
                    android:textAppearance="@style/TextAppearance.Game.Subtitle" />
                <TextView
                    android:id="@+id/alert_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/cst_pad_6"
                    android:text="@string/label_default_alert"
                    android:textAppearance="@style/TextAppearance.Game.Body" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/cst_bottom_bar_h"
            android:background="@drawable/ui_panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="@dimen/cst_pad_12"
            android:paddingRight="@dimen/cst_pad_12">

            <Button
                android:id="@+id/btn_ratio"
                style="@style/Widget.Game.Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50%"
                android:textAllCaps="false" />

            <View
                android:layout_width="@dimen/cst_pad_8"
                android:layout_height="0dp" />

            <Button
                android:id="@+id/btn_ability_rally"
                style="@style/Widget.Game.Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rally"
                android:textAllCaps="false" />

            <View
                android:layout_width="@dimen/cst_pad_8"
                android:layout_height="0dp" />

            <Button
                android:id="@+id/btn_ability_shield"
                style="@style/Widget.Game.Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shield"
                android:textAllCaps="false" />

            <View
                android:layout_width="@dimen/cst_pad_8"
                android:layout_height="0dp" />

            <Button
                android:id="@+id/btn_ability_scout"
                style="@style/Widget.Game.Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scout"
                android:textAllCaps="false" />

            <View
                android:layout_width="@dimen/cst_pad_8"
                android:layout_height="0dp" />

            <Button
                android:id="@+id/btn_ability_repair"
                style="@style/Widget.Game.Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Repair"
                android:textAllCaps="false" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/menu_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/ui_dialog">
        <LinearLayout
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/ui_panel"
            android:orientation="vertical"
            android:padding="@dimen/cst_pad_24">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textAppearance="@style/TextAppearance.Game.Title" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cst_pad_6"
                android:text="@string/label_menu_pitch"
                android:textAppearance="@style/TextAppearance.Game.Body" />
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/cst_pad_16" />
            <Button
                android:id="@+id/btn_menu_campaign"
                style="@style/Widget.Game.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_start"
                android:textAllCaps="false" />
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/cst_pad_8" />
            <Button
                android:id="@+id/btn_menu_upgrades"
                style="@style/Widget.Game.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_upgrades"
                android:textAllCaps="false" />
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/cst_pad_8" />
            <Button
                android:id="@+id/btn_menu_help"
                style="@style/Widget.Game.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_how_to_play"
                android:textAllCaps="false" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/chapter_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/ui_dialog"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="520dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/ui_panel"
            android:orientation="vertical"
            android:padding="@dimen/cst_pad_20">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_choose_province"
                android:textAppearance="@style/TextAppearance.Game.Title" />
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cst_pad_12"
                android:columnCount="2">
                <Button android:id="@+id/btn_chapter_1" style="@style/Widget.Game.Button.Primary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="1 Northmarch Vale" android:textAllCaps="false" />
                <Button android:id="@+id/btn_chapter_2" style="@style/Widget.Game.Button.Primary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="2 Bridgewatch Reaches" android:textAllCaps="false" />
                <Button android:id="@+id/btn_chapter_3" style="@style/Widget.Game.Button.Primary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="3 Oakwall Corridor" android:textAllCaps="false" />
                <Button android:id="@+id/btn_chapter_4" style="@style/Widget.Game.Button.Primary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="4 Twinroad Bastions" android:textAllCaps="false" />
                <Button android:id="@+id/btn_chapter_5" style="@style/Widget.Game.Button.Primary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="5 Ironford Siege" android:textAllCaps="false" />
                <Button android:id="@+id/btn_chapter_6" style="@style/Widget.Game.Button.Primary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="6 Goldwind Pass" android:textAllCaps="false" />
                <Button android:id="@+id/btn_chapter_7" style="@style/Widget.Game.Button.Primary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="7 Ravenpost Downs" android:textAllCaps="false" />
                <Button android:id="@+id/btn_chapter_8" style="@style/Widget.Game.Button.Primary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="8 Southgate Circuit" android:textAllCaps="false" />
                <Button android:id="@+id/btn_chapter_9" style="@style/Widget.Game.Button.Primary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="9 Kingroad Expanse" android:textAllCaps="false" />
                <Button android:id="@+id/btn_chapter_10" style="@style/Widget.Game.Button.Primary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="10 Crownfire Capital" android:textAllCaps="false" />
            </GridLayout>
            <View android:layout_width="match_parent" android:layout_height="@dimen/cst_pad_12" />
            <Button
                android:id="@+id/btn_chapter_back"
                style="@style/Widget.Game.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_menu"
                android:textAllCaps="false" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/upgrade_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/ui_dialog"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="360dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/ui_panel"
            android:orientation="vertical"
            android:padding="@dimen/cst_pad_20">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/btn_upgrades" android:textAppearance="@style/TextAppearance.Game.Title" />
            <TextView android:id="@+id/upgrade_logistics_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_12" android:text="Lv 0" android:textAppearance="@style/TextAppearance.Game.Body" />
            <Button android:id="@+id/btn_upgrade_logistics" style="@style/Widget.Game.Button.Primary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/label_upgrade_logistics" android:textAllCaps="false" />
            <TextView android:id="@+id/upgrade_council_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_12" android:text="Lv 0" android:textAppearance="@style/TextAppearance.Game.Body" />
            <Button android:id="@+id/btn_upgrade_council" style="@style/Widget.Game.Button.Primary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/label_upgrade_council" android:textAllCaps="false" />
            <TextView android:id="@+id/upgrade_discipline_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_12" android:text="Lv 0" android:textAppearance="@style/TextAppearance.Game.Body" />
            <Button android:id="@+id/btn_upgrade_discipline" style="@style/Widget.Game.Button.Primary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/label_upgrade_discipline" android:textAllCaps="false" />
            <View android:layout_width="match_parent" android:layout_height="@dimen/cst_pad_12" />
            <Button android:id="@+id/btn_upgrade_back" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/btn_menu" android:textAllCaps="false" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/help_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/ui_dialog"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="420dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/ui_panel"
            android:orientation="vertical"
            android:padding="@dimen/cst_pad_20">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/btn_how_to_play" android:textAppearance="@style/TextAppearance.Game.Title" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_12" android:text="@string/text_help_body" android:textAppearance="@style/TextAppearance.Game.Body" />
            <View android:layout_width="match_parent" android:layout_height="@dimen/cst_pad_12" />
            <Button android:id="@+id/btn_help_back" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/btn_menu" android:textAllCaps="false" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/pause_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/ui_dialog"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/ui_panel"
            android:orientation="vertical"
            android:padding="@dimen/cst_pad_20">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/btn_pause" android:textAppearance="@style/TextAppearance.Game.Title" />
            <View android:layout_width="match_parent" android:layout_height="@dimen/cst_pad_12" />
            <Button android:id="@+id/btn_pause_resume" style="@style/Widget.Game.Button.Primary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/btn_resume" android:textAllCaps="false" />
            <View android:layout_width="match_parent" android:layout_height="@dimen/cst_pad_8" />
            <Button android:id="@+id/btn_pause_menu" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/btn_menu" android:textAllCaps="false" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/result_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/ui_dialog"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="360dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/ui_panel"
            android:orientation="vertical"
            android:padding="@dimen/cst_pad_20">
            <TextView android:id="@+id/result_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_victory" android:textAppearance="@style/TextAppearance.Game.Title" />
            <TextView android:id="@+id/result_summary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/cst_pad_12" android:text="@string/label_result_placeholder" android:textAppearance="@style/TextAppearance.Game.Body" />
            <View android:layout_width="match_parent" android:layout_height="@dimen/cst_pad_12" />
            <Button android:id="@+id/btn_result_next" style="@style/Widget.Game.Button.Primary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/btn_next_province" android:textAllCaps="false" />
            <View android:layout_width="match_parent" android:layout_height="@dimen/cst_pad_8" />
            <Button android:id="@+id/btn_result_retry" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/btn_restart" android:textAllCaps="false" />
            <View android:layout_width="match_parent" android:layout_height="@dimen/cst_pad_8" />
            <Button android:id="@+id/btn_result_menu" style="@style/Widget.Game.Button.Secondary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/btn_menu" android:textAllCaps="false" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
